// ==UserScript==
// @name         ELT Hybrid Client v10.5 - Şimşekli Customizer
// @match        https://bloxd.io/*
// @grant        none
// ==/UserScript==

(function() {
    'use strict';

    let state = {
        pelerinAcik: true,
        menuAcik: false,
        genislik: 45,
        yukseklik: 95,
        incelik: 600,
        hiz: 0
    };

    // --- 1. MOD MENÜSÜ (Sadece Boyut Ayarları) ---
    const menuDiv = document.createElement("div");
    menuDiv.style = `
        position: fixed; top: 50%; left: 85%; transform: translate(-50%, -50%);
        width: 220px; background: rgba(0, 0, 0, 0.9); border: 2px solid #FFD700;
        border-radius: 10px; padding: 15px; z-index: 10000; display: none;
        color: white; font-family: sans-serif; text-align: center; box-shadow: 0 0 15px #FFD700;
    `;
    menuDiv.innerHTML = `
        <h3 style="margin:0; color:#FFD700;">ELT SETTINGS</h3>
        <p style="font-size:10px;">Menü: <b>*</b> | Pelerin: <b>Shift</b></p>
        <hr border="1" color="#FFD700">
        <div style="text-align:left; font-size:12px;">
            <label>Genişlik: <span id="wV">45</span></label>
            <input type="range" id="wS" min="20" max="80" value="45" style="width:100%;">
            <br><br>
            <label>Yükseklik: <span id="hV">95</span></label>
            <input type="range" id="hS" min="50" max="150" value="95" style="width:100%;">
            <br><br>
            <label>İncelik: <span id="dV">600</span></label>
            <input type="range" id="dS" min="200" max="1200" value="600" style="width:100%;">
        </div>
    `;
    document.body.appendChild(menuDiv);

    // --- 2. PELERİN VE SARI ŞİMŞEK ---
    const capeDiv = document.createElement("div");
    capeDiv.style = `position: fixed; left: 50%; top: 52.5%; pointer-events: none; z-index: 1; transform: translateX(-50%); perspective: 600px;`;
    
    const capeInner = document.createElement("div");
    capeInner.style = `width:100%; height:100%; background-size:100% 100%; transform-origin:top; transition: transform 0.1s;`;

    function drawCape() {
        const cvs = document.createElement("canvas");
        const cx = cvs.getContext("2d");
        cvs.width = 40; cvs.height = 100;

        // Arka Plan Renkleri (Klasik ELT)
        cx.fillStyle = "blue";  cx.fillRect(0, 0, 20, 50);
        cx.fillStyle = "white"; cx.fillRect(20, 0, 20, 50);
        cx.fillStyle = "cyan";  cx.fillRect(0, 50, 20, 50);
        cx.fillStyle = "red";   cx.fillRect(20, 50, 20, 50);

        // Kırmızı ELT Yazısı
        cx.fillStyle = "red";
        cx.font = "bold 10px Arial";
        cx.textAlign = "center";
        cx.fillText("ELT", 20, 15);

        // O MEŞHUR SARI ŞİMŞEK LOGOSU
        cx.fillStyle = "#FFD700"; 
        cx.fillRect(12, 35, 16, 16); // Altın kare
        cx.fillStyle = "white"; 
        cx.font = "14px Arial"; 
        cx.fillText("⚡", 20, 48);

        capeInner.style.backgroundImage = `url(${cvs.toDataURL()})`;
    }

    capeDiv.appendChild(capeInner);
    document.body.appendChild(capeDiv);
    drawCape();

    // --- 3. TUŞ KONTROLLERİ ---
    window.addEventListener('keydown', (e) => {
        // * Tuşu Menü Aç/Kapat
        if(e.key === '*' || e.code === 'NumpadMultiply') {
            state.menuAcik = !state.menuAcik;
            menuDiv.style.display = state.menuAcik ? "block" : "none";
        }
        // Shift Tuşu Pelerin Gizle/Göster
        if(e.key === 'Shift') {
            state.pelerinAcik = !state.pelerinAcik;
        }
        
        if(['KeyW','KeyS','KeyA','KeyD'].includes(e.code)) state.hiz = 15;
    });

    window.addEventListener('keyup', (e) => {
        if(['KeyW','KeyS','KeyA','KeyD'].includes(e.code)) state.hiz = 0;
    });

    // Slider Güncellemeleri
    const update = () => {
        state.genislik = document.getElementById("wS").value;
        state.yukseklik = document.getElementById("hS").value;
        state.incelik = document.getElementById("dS").value;
        
        document.getElementById("wV").innerText = state.genislik;
        document.getElementById("hV").innerText = state.yukseklik;
        document.getElementById("dV").innerText = state.incelik;

        capeDiv.style.width = state.genislik + "px";
        capeDiv.style.height = state.yukseklik + "px";
        capeDiv.style.perspective = state.incelik + "px";
    };

    document.getElementById("wS").oninput = update;
    document.getElementById("hS").oninput = update;
    document.getElementById("dS").oninput = update;

    // --- 4. ANİMASYON DÖNGÜSÜ ---
    function loop(currentTime) {
        if(state.pelerinAcik) {
            capeDiv.style.display = "block";
            let wave = Math.sin(currentTime / 200) * 5;
            capeInner.style.transform = `rotateX(${10 + state.hiz + wave}deg)`;
        } else {
            capeDiv.style.display = "none";
        }
        requestAnimationFrame(loop);
    }

    update(); // İlk ayarları uygula
    requestAnimationFrame(loop);
    console.log("ELT v10.5 Aktif! Yıldız(*) Menü, Shift Pelerin Gizleme.");
})();
